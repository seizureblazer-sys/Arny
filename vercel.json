{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/fetch-url",
      "destination": "/api/fetch-url.ts"
    },
    {
      "source": "/api/ai/stream",
      "destination": "/api/ai-stream.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
